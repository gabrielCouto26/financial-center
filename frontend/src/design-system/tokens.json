{
  "meta": {
    "name": "financial-center-design-system",
    "source": "figma-print",
    "version": "1.0.0"
  },
  "colors": {
    "primary": {
      "500": "#1F6FEB"
    },
    "secondary": {
      "500": "#2DA44E"
    },
    "accent": {
      "500": "#D1242F"
    },
    "highlight": {
      "500": "#F59E0B"
    },
    "neutral": {
      "0": "#FFFFFF",
      "50": "#F6F8FA",
      "100": "#EAECEF",
      "200": "#D0D7DE",
      "300": "#AFB8C1",
      "400": "#8C959F",
      "500": "#6E7781",
      "600": "#57606A",
      "700": "#424A53",
      "800": "#32383F",
      "900": "#24292F"
    },
    "background": {
      "default": "#F6F8FA",
      "surface": "#FFFFFF",
      "sidebar": "#FFFFFF",
      "card": "#FFFFFF"
    },
    "text": {
      "primary": "#24292F",
      "secondary": "#57606A",
      "muted": "#8C959F",
      "inverse": "#FFFFFF",
      "success": "#2DA44E",
      "danger": "#D1242F"
    },
    "border": {
      "default": "#EAECEF",
      "subtle": "#D0D7DE",
      "focus": "#1F6FEB"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Inter, system-ui, sans-serif"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "32px"
    },
    "lineHeight": {
      "sm": 1.3,
      "md": 1.5,
      "lg": 1.6
    },
    "usage": {
      "title": {
        "size": "32px",
        "weight": 700
      },
      "subtitle": {
        "size": "18px",
        "weight": 500
      },
      "body": {
        "size": "14px",
        "weight": 400
      },
      "caption": {
        "size": "12px",
        "weight": 400
      }
    }
  },
  "spacing": {
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48]
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "xl": "20px"
  },
  "shadows": {
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "md": "0 4px 12px rgba(0,0,0,0.08)",
    "lg": "0 10px 24px rgba(0,0,0,0.12)"
  },
  "layout": {
    "sidebar": {
      "width": "240px",
      "background": "{colors.background.sidebar}"
    },
    "header": {
      "height": "64px",
      "background": "{colors.background.surface}"
    },
    "content": {
      "maxWidth": "1200px",
      "padding": "24px"
    }
  },
  "components": {
    "button": {
      "height": "36px",
      "paddingX": "16px",
      "radius": "full",
      "fontSize": "14px",
      "variants": {
        "primary": {
          "bg": "{colors.primary.500}",
          "text": "#FFFFFF"
        },
        "secondary": {
          "bg": "#EAECEF",
          "text": "{colors.text.primary}"
        },
        "text": {
          "bg": "transparent",
          "text": "{colors.primary.500}"
        },
        "icon": {
          "size": "32px",
          "radius": "full",
          "bg": "{colors.accent.500}",
          "text": "#FFFFFF"
        }
      }
    },
    "input": {
      "height": "36px",
      "paddingX": "12px",
      "radius": "md",
      "background": "#FFFFFF",
      "border": "{colors.border.default}",
      "placeholder": "{colors.text.muted}"
    },
    "card": {
      "padding": "16px",
      "radius": "lg",
      "background": "#FFFFFF",
      "shadow": "{shadows.md}"
    },
    "badge": {
      "radius": "full",
      "paddingX": "8px",
      "paddingY": "4px",
      "fontSize": "12px",
      "variants": {
        "success": {
          "bg": "#E6F4EA",
          "text": "{colors.secondary.500}"
        }
      }
    },
    "transactionItem": {
      "height": "56px",
      "padding": "12px 16px",
      "background": "#FFFFFF",
      "border": "{colors.border.default}",
      "radius": "md"
    }
  },
  "rules": {
    "layout": [
      "Sidebar fixa à esquerda com navegação vertical",
      "Header horizontal com ações e busca",
      "Conteúdo central com cards em grid",
      "Espaçamento consistente baseado em múltiplos de 8px"
    ],
    "visual": [
      "Uso predominante de fundo claro (light theme)",
      "Cards com leve sombra para hierarquia",
      "Elementos com cantos arredondados (>= 10px)"
    ],
    "colors": [
      "Azul = ação principal",
      "Verde = valores positivos / saldo",
      "Vermelho = alerta / negativo",
      "Laranja = destaque informacional",
      "Cinza = estrutura e textos secundários"
    ],
    "typography": [
      "Títulos grandes e bold para hierarquia clara",
      "Texto secundário em tons de cinza",
      "Valores financeiros com destaque visual (peso maior ou cor)"
    ],
    "components": [
      "Botões principais sempre arredondados (pill)",
      "Inputs com borda sutil e fundo branco",
      "Cards agrupam informação relacionada",
      "Lista de transações com separação por blocos"
    ],
    "ux": [
      "Destaque de saldo principal em card grande",
      "Feedback visual para ganhos (verde) e gastos (cinza/vermelho)",
      "Ações principais sempre visíveis (ex: + New Expense)",
      "Uso de ícones para reforço visual"
    ],
    "responsiveness": [
      "Grid de cards colapsa para 1 coluna no mobile",
      "Sidebar vira menu colapsável",
      "Espaçamento reduz proporcionalmente"
    ]
  }
}