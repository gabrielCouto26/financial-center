{
  "name": "financial-center",
  "version": "1.0.0",
  "description": "Monorepo layout: `backend/` (NestJS + Prisma + PostgreSQL), `frontend/` (Vite + React + TypeScript).",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "prepare": "husky",
    "lint:backend": "pnpm --filter backend lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "lint:all": "pnpm --filter backend lint && pnpm --filter frontend lint",
    "typecheck:frontend": "pnpm --filter frontend typecheck",
    "test:all": "pnpm --filter backend test && pnpm --filter frontend typecheck",
    "test:backend": "pnpm --filter backend test",
    "clean:cache": "npx tsx scripts/cleanGeminiCache.ts"
  },
  "lint-staged": {
    "apps/backend/src/**/*.ts": [
      "eslint --fix --config apps/backend/eslint.config.mjs",
      "prettier --write --config apps/backend/.prettierrc"
    ],
    "apps/frontend/src/**/*.{ts,tsx}": [
      "eslint --fix --config apps/frontend/eslint.config.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielCouto26/financial-center.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gabrielCouto26/financial-center/issues"
  },
  "homepage": "https://github.com/gabrielCouto26/financial-center#readme",
  "devDependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0"
  }
}