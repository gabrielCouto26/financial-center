// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String?
  passwordHash     String            @map("password_hash")
  passwordResetTokenHash String?     @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime?   @map("password_reset_expires_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  coupleMembership CoupleLinkMember?
  createdTransactions Transaction[]  @relation("CreatedTransactions")
  paidTransactions    Transaction[]  @relation("PaidTransactions")
  transactionSplits   TransactionSplit[]
  createdGroups       Group[]        @relation("CreatedGroups")
  groupMemberships    GroupMember[]

  @@map("users")
}

model CoupleLink {
  id        String             @id @default(uuid())
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  members   CoupleLinkMember[]
  transactions Transaction[]   @relation("CoupleLinkTransactions")

  @@map("couple_links")
}

model CoupleLinkMember {
  id           String     @id @default(uuid())
  coupleLinkId String     @map("couple_link_id")
  userId       String     @unique @map("user_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  coupleLink   CoupleLink @relation(fields: [coupleLinkId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coupleLinkId, userId])
  @@map("couple_link_members")
}

enum Category {
  FOOD
  TRANSPORT
  HOUSING
  ENTERTAINMENT
  HEALTH
  SHOPPING
  EDUCATION
  UTILITIES
  OTHER
}

enum TransactionType {
  PERSONAL
  COUPLE
  GROUP
}

enum TransactionDirection {
  INCOME
  EXPENSE
}

model Group {
  id              String        @id @default(uuid())
  name            String
  createdByUserId String        @map("created_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  createdBy       User          @relation("CreatedGroups", fields: [createdByUserId], references: [id], onDelete: Cascade)
  members         GroupMember[]
  transactions    Transaction[] @relation("GroupTransactions")

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId    String   @map("group_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Transaction {
  id            String            @id @default(uuid())
  name          String
  amount        Decimal           @db.Decimal(10, 2)
  category      Category
  type          TransactionType   @default(PERSONAL)
  direction     TransactionDirection @default(EXPENSE)
  date          DateTime
  creatorUserId String            @map("user_id")
  paidByUserId  String            @map("paid_by_user_id")
  coupleLinkId  String?           @map("couple_link_id")
  groupId       String?           @map("group_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  coupleLink    CoupleLink?       @relation("CoupleLinkTransactions", fields: [coupleLinkId], references: [id], onDelete: Cascade)
  group         Group?            @relation("GroupTransactions", fields: [groupId], references: [id], onDelete: Cascade)
  creator       User              @relation("CreatedTransactions", fields: [creatorUserId], references: [id], onDelete: Cascade)
  payer         User              @relation("PaidTransactions", fields: [paidByUserId], references: [id], onDelete: Cascade)
  splits        TransactionSplit[]

  @@map("transactions")
}

model TransactionSplit {
  id            String      @id @default(uuid())
  transactionId String      @map("transaction_id")
  userId        String      @map("user_id")
  percentage    Decimal     @db.Decimal(5, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([transactionId, userId])
  @@map("transaction_splits")
}
