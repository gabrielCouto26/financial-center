{
  "meta": {
    "name": "financial-center-design-system",
    "source": "figma-print",
    "version": "1.1.0"
  },
  "colors": {
    "primary": {
      "50": "#DBEAFE",
      "500": "#1D4ED8",
      "600": "#1E40AF",
      "ghost": "rgba(29, 78, 216, 0.05)"
    },
    "secondary": {
      "50": "#E6F4EA",
      "500": "#2DA44E",
      "600": "#166534"
    },
    "accent": {
      "50": "#FEE2E2",
      "500": "#D1242F",
      "600": "#991B1B",
      "700": "#DC2626"
    },
    "highlight": {
      "50": "#FEF3C7",
      "500": "#F59E0B",
      "700": "#92400E"
    },
    "info": {
      "50": "#DBEAFE",
      "500": "#1D4ED8",
      "600": "#1E40AF"
    },
    "insight": {
      "500": "#8B5E3C",
      "gradient": "linear-gradient(135deg, #8B5E3C, #5D4037)"
    },
    "brand": {
      "700": "#003B75",
      "800": "#00388D",
      "gradient": "linear-gradient(135deg, #24292F, #1D4ED8)"
    },
    "neutral": {
      "0": "#FFFFFF",
      "25": "#F8FAFC",
      "50": "#F6F8FA",
      "75": "#F3F4F6",
      "100": "#EAECEF",
      "150": "#F1F5F9",
      "200": "#D0D7DE",
      "250": "#E2E8F0",
      "300": "#AFB8C1",
      "350": "#CBD5E1",
      "400": "#8C959F",
      "450": "#94A3B8",
      "500": "#6E7781",
      "600": "#57606A",
      "700": "#424A53",
      "800": "#32383F",
      "850": "#1E293B",
      "900": "#24292F"
    },
    "background": {
      "default": "#F6F8FA",
      "surface": "#FFFFFF",
      "sidebar": "{colors.background.surface}",
      "card": "{colors.background.surface}",
      "canvas": "{colors.neutral.25}",
      "muted": "{colors.neutral.150}",
      "subtle": "{colors.neutral.75}",
      "chrome": "{colors.neutral.250}",
      "success": "{colors.secondary.50}",
      "danger": "{colors.accent.50}",
      "warning": "{colors.highlight.50}",
      "info": "{colors.info.50}"
    },
    "text": {
      "primary": "#24292F",
      "secondary": "#57606A",
      "muted": "#8C959F",
      "tertiary": "#94A3B8",
      "strong": "#1E293B",
      "inverse": "#FFFFFF",
      "success": "#2DA44E",
      "successStrong": "#166534",
      "danger": "#D1242F",
      "dangerStrong": "#991B1B",
      "warning": "#92400E",
      "info": "#1E40AF",
      "brand": "#1D4ED8",
      "brandMuted": "#003B75",
      "brandStrong": "#00388D"
    },
    "border": {
      "default": "#EAECEF",
      "subtle": "#D0D7DE",
      "focus": "#1F6FEB",
      "muted": "#F1F5F9",
      "strong": "#CBD5E1",
      "inverse": "#FFFFFF"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Inter, system-ui, sans-serif",
      "display": "'Plus Jakarta Sans', system-ui, sans-serif"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "fontSize": {
      "10": "10px",
      "11": "11px",
      "12": "12px",
      "13": "13px",
      "14": "14px",
      "16": "16px",
      "18": "18px",
      "20": "20px",
      "24": "24px",
      "32": "32px",
      "48": "48px",
      "72": "72px"
    },
    "lineHeight": {
      "tight": 1,
      "compact": 1.1,
      "sm": 1.3,
      "md": 1.5,
      "lg": 1.6
    },
    "usage": {
      "title": {
        "size": "{typography.fontSize.32}",
        "weight": "{typography.fontWeight.bold}"
      },
      "subtitle": {
        "size": "{typography.fontSize.18}",
        "weight": "{typography.fontWeight.medium}"
      },
      "body": {
        "size": "{typography.fontSize.14}",
        "weight": "{typography.fontWeight.regular}"
      },
      "caption": {
        "size": "{typography.fontSize.12}",
        "weight": "{typography.fontWeight.regular}"
      }
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px"
  },
  "radius": {
    "xxs": "3px",
    "xs": "4px",
    "sm": "6px",
    "base": "8px",
    "md": "10px",
    "lg": "12px",
    "xl": "14px",
    "2xl": "20px",
    "full": "9999px"
  },
  "shadows": {
    "soft": "0 1px 3px rgba(0,0,0,0.02)",
    "xs": "0 1px 3px rgba(0, 0, 0, 0.05)",
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "subtle": "0 2px 4px rgba(0,0,0,0.04)",
    "md": "0 4px 12px rgba(0,0,0,0.08)",
    "lg": "0 10px 24px rgba(0,0,0,0.12)",
    "ring": "0 0 0 1px #E2E8F0"
  },
  "layout": {
    "sidebar": {
      "width": "240px",
      "dashboardWidth": "280px",
      "background": "{colors.background.sidebar}"
    },
    "header": {
      "height": "64px",
      "dashboardHeight": "72px",
      "background": "{colors.background.surface}"
    },
    "content": {
      "maxWidth": "1200px",
      "narrowWidth": "1000px",
      "padding": "24px"
    },
    "search": {
      "dashboardWidth": "320px",
      "personalMaxWidth": "400px",
      "personalInset": "36px",
      "dashboardInset": "44px",
      "personalHeight": "36px",
      "dashboardHeight": "44px"
    },
    "auth": {
      "maxWidth": "600px",
      "topMargin": "100px"
    },
    "form": {
      "maxWidth": "22rem"
    },
    "grid": {
      "balanceMin": "140px"
    },
    "legacy": {
      "sidebarWidth": "300px"
    },
    "breakpoint": {
      "mobile": "768px"
    }
  },
  "size": {
    "avatar": {
      "stack": "28px",
      "default": "36px",
      "group": "52px"
    },
    "icon": {
      "button": "32px",
      "summary": "40px",
      "transaction": "56px"
    }
  },
  "components": {
    "button": {
      "paddingX": "16px",
      "radius": "{radius.full}",
      "fontSize": "{typography.fontSize.14}",
      "sizes": {
        "sm": {
          "height": "32px",
          "paddingX": "12px",
          "fontSize": "{typography.fontSize.12}"
        },
        "md": {
          "height": "40px",
          "paddingX": "20px",
          "fontSize": "{typography.fontSize.14}"
        },
        "lg": {
          "height": "48px",
          "paddingX": "24px",
          "fontSize": "{typography.fontSize.16}"
        }
      },
      "variants": {
        "primary": {
          "bg": "{colors.primary.500}",
          "text": "{colors.text.inverse}"
        },
        "secondary": {
          "bg": "transparent",
          "border": "{colors.primary.500}",
          "text": "{colors.primary.500}",
          "hoverBg": "{colors.primary.ghost}"
        },
        "text": {
          "bg": "transparent",
          "text": "{colors.primary.500}"
        }
      }
    },
    "input": {
      "height": "36px",
      "paddingX": "12px",
      "radius": "{radius.md}",
      "background": "{colors.background.surface}",
      "border": "{colors.border.default}",
      "placeholder": "{colors.text.muted}",
      "labelFontSize": "{typography.fontSize.10}",
      "errorFontSize": "{typography.fontSize.12}",
      "underlineWidth": "2px"
    },
    "card": {
      "padding": "{spacing.4}",
      "radius": "{radius.xl}",
      "background": "{colors.background.surface}",
      "shadow": "{shadows.md}"
    },
    "badge": {
      "radius": "{radius.full}",
      "paddingX": "{spacing.2}",
      "paddingY": "2px",
      "fontSize": "{typography.fontSize.11}",
      "variants": {
        "success": {
          "bg": "{colors.background.success}",
          "text": "{colors.text.successStrong}"
        },
        "danger": {
          "bg": "{colors.background.danger}",
          "text": "{colors.text.dangerStrong}"
        },
        "warning": {
          "bg": "{colors.background.warning}",
          "text": "{colors.text.warning}"
        },
        "info": {
          "bg": "{colors.background.info}",
          "text": "{colors.text.info}"
        },
        "neutral": {
          "bg": "{colors.neutral.100}",
          "text": "{colors.neutral.700}"
        }
      }
    },
    "transactionItem": {
      "height": "56px",
      "padding": "12px 16px",
      "background": "{colors.background.surface}",
      "border": "{colors.border.default}",
      "radius": "{radius.2xl}",
      "shadow": "{shadows.xs}"
    }
  },
  "rules": {
    "layout": [
      "Sidebar fixa à esquerda com navegação vertical",
      "Header horizontal com ações e busca",
      "Conteúdo central com cards em grid",
      "Espaçamento consistente baseado em múltiplos de 8px"
    ],
    "visual": [
      "Uso predominante de fundo claro (light theme)",
      "Cards com leve sombra para hierarquia",
      "Elementos com cantos arredondados (>= 10px)"
    ],
    "colors": [
      "Azul = ação principal",
      "Verde = valores positivos / saldo",
      "Vermelho = alerta / negativo",
      "Laranja = destaque informacional",
      "Cinza = estrutura e textos secundários"
    ],
    "typography": [
      "Títulos grandes e bold para hierarquia clara",
      "Texto secundário em tons de cinza",
      "Valores financeiros com destaque visual (peso maior ou cor)"
    ],
    "components": [
      "Botões principais sempre arredondados (pill)",
      "Inputs com borda sutil e fundo branco",
      "Cards agrupam informação relacionada",
      "Lista de transações com separação por blocos"
    ],
    "ux": [
      "Destaque de saldo principal em card grande",
      "Feedback visual para ganhos (verde) e gastos (cinza/vermelho)",
      "Ações principais sempre visíveis (ex: + New Expense)",
      "Uso de ícones para reforço visual"
    ],
    "responsiveness": [
      "Grid de cards colapsa para 1 coluna no mobile",
      "Sidebar vira menu colapsável",
      "Espaçamento reduz proporcionalmente"
    ]
  }
}
